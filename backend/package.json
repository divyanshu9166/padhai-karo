  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "9.1.0",
    "fast-check": "3.22.0",
    "prettier": "3.3.3",
    "prisma": "^6.19.3",
    "typescript": "5.5.4",
