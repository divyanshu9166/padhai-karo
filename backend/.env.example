# Server-side-only environment variables. NEVER bundle these into the mobile client.
# Copy to .env.local for local development. All variables below are REQUIRED and are
# validated at startup by src/lib/config (a missing/blank value fails fast with a clear
# error). These are server-only secrets and must never be shipped via the client OTA
# bundle (see design "Security Considerations: Transport & Secrets").

# Database (PostgreSQL via Prisma datasource `DATABASE_URL`) - task 1.2 / 1.3
DATABASE_URL=postgresql://user:password@localhost:5432/jee_neet_study

# Redis (BullMQ queues + session cache) - task 1.2
REDIS_URL=redis://localhost:6379

# AI provider (Gemini / Claude, vision-capable) - used by AI notes (task 16) + extraction (task 12)
AI_PROVIDER_API_KEY=

# Razorpay (subscription payments + webhook signature verification) - task 16
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
